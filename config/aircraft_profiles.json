{
  "aircraft_profiles": {
    "PMDG_737": {
      "name": "PMDG 737",
      "manufacturer": "PMDG",
      "type": "Boeing 737",
      "requires_lvars": true,
      "autopilot": {
        "type": "custom",
        "commands": {
          "autopilot_master": {
            "method": "event",
            "event": "PMDG_737_MCP_AP_ENGAGE",
            "event_off": "PMDG_737_MCP_AP_DISENGAGE"
          },
          "heading": {
            "method": "lvar",
            "variable": "PMDG_737_MCP_Course",
            "event": "PMDG_737_MCP_COURSE_SELECTOR"
          },
          "altitude": {
            "method": "lvar",
            "variable": "PMDG_737_MCP_Altitude",
            "event": "PMDG_737_MCP_ALT_SELECTOR"
          },
          "vertical_speed": {
            "method": "lvar",
            "variable": "PMDG_737_MCP_VertSpeed",
            "event": "PMDG_737_MCP_VS_SELECTOR"
          },
          "approach_mode": {
            "method": "event",
            "event": "PMDG_737_MCP_APP_SWITCH"
          },
          "nav_mode": {
            "method": "event",
            "event": "PMDG_737_MCP_LNAV_SWITCH"
          },
          "localizer_mode": {
            "method": "event",
            "event": "PMDG_737_MCP_LOC_SWITCH"
          }
        },
        "status_variables": {
          "autopilot_engaged": "PMDG_737_MCP_AP_Engaged",
          "approach_armed": "PMDG_737_MCP_APP_Armed",
          "nav_armed": "PMDG_737_MCP_LNAV_Armed"
        }
      },
      "autothrottle": {
        "supported": true,
        "commands": {
          "set_speed": {
            "method": "lvar",
            "variable": "PMDG_737_MCP_IASMach",
            "event": "PMDG_737_MCP_SPEED_SELECTOR"
          },
          "engage": {
            "method": "event",
            "event": "PMDG_737_MCP_AT_ARM_SWITCH"
          }
        }
      },
      "limitations": {
        "max_bank_angle": 25,
        "min_approach_speed": 130,
        "max_approach_speed": 160,
        "requires_fms_programming": true
      }
    },
